{
  "name": "APV Foss",
  "description": "Internal use only. Gets info on Family Accounts and allows them to be quickly copied to the clipboard.",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "js": ["main.js"],
      "matches": [
        "https://freestyle.fossswimschool.com/*"
      ]
    }
  ],
  "web_accessible_resources": [{
    "matches": ["<all_urls>"],
    "resources": ["plus-solid-full.svg", "check-solid-full.svg", "spinner-solid-full.svg", "print-solid-full.svg", "pen-to-square-regular-full.svg"]
    }]
}